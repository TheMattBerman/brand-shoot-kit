# Brand Shoot Kit optional environment variables.
# None are required for planning mode.

# Enables GPT Image/OpenAI API generation or image edits when integrated.
# Without this: kit still outputs full plan + prompts.
OPENAI_API_KEY=

# Optional fallback provider for vision/image analysis.
# Without this: QA remains checklist/manual.
GOOGLE_AI_API_KEY=

# Optional high-fidelity page extraction.
# Without this: scripts use basic URL fetch + HTML parsing.
FIRECRAWL_API_KEY=

# Optional social/source extraction.
# Without this: brand scout uses provided URLs and page content only.
APIFY_API_TOKEN=

# Optional alternate generation backend.
# Without this: alternate backend features are skipped.
REPLICATE_API_TOKEN=
